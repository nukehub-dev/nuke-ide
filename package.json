{
  "private": true,
  "engines": {
    "yarn": ">=1.7.0 <2",
    "node": ">=22"
  },
  "resolutions": {
    "node-abi": "4.33.0",
    "@electron/rebuild": "4.2.0",
    "nan": "2.28.0",
    "@theia/monaco-editor-core": "1.108.201",
    "**/ssh2": "1.17.0"
  },
  "scripts": {
    "download:plugins": "theia download:plugins --rate-limit=15 --parallel=false --ignore-errors",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:python": "ruff check --fix extensions && ruff format extensions",
    "lint": "yarn format:check && yarn lint:python",
    "lint:python": "ruff check extensions && ruff format --check extensions",
    "generate:preload": "node scripts/generate-preload.js",
    "build:browser": "yarn generate:preload && yarn --cwd applications/browser bundle",
    "build:electron": "yarn generate:preload && yarn --cwd applications/electron bundle",
    "bump-version": "node scripts/bump-version.js",
    "test:python": "python -m pytest",
    "test:python:cov": "python -m pytest --cov --cov-report=term-missing --cov-report=xml",
    "test:ts": "vitest run",
    "docker:build": "docker compose -f applications/docker/compose.yml build",
    "docker:up": "docker compose -f applications/docker/compose.yml up",
    "build:electron:prod": "yarn generate:preload && yarn download:plugins && yarn --cwd applications/electron bundle:prod",
    "prepare": "lerna run prepare",
    "postinstall": "theia check:theia-version",
    "start:browser": "yarn --cwd applications/browser start",
    "start:electron": "yarn --cwd applications/electron start",
    "watch:browser": "lerna run --parallel watch --ignore applications/electron",
    "watch:electron": "lerna run --parallel watch --ignore applications/browser",
    "dist": "yarn --cwd applications/electron dist",
    "dist:dir": "yarn --cwd applications/electron dist:dir",
    "package:electron": "yarn build:electron:prod && yarn dist",
    "package:electron:all": "yarn build:electron:prod && yarn --cwd applications/electron dist -mwl"
  },
  "devDependencies": {
    "lerna": "2.4.0",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10"
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "eclipse-theia.builtin-extension-pack": "https://open-vsx.org/api/eclipse-theia/builtin-extension-pack/1.104.0/file/eclipse-theia.builtin-extension-pack-1.104.0.vsix",
    "ms-python.python": "https://open-vsx.org/api/ms-python/python/2026.2.0/file/ms-python.python-2026.2.0.vsix",
    "ms-toolsai.jupyter": "https://open-vsx.org/api/ms-toolsai/jupyter/2025.9.1/file/ms-toolsai.jupyter-2025.9.1.vsix",
    "pkief.material-icon-theme": "https://open-vsx.org/api/PKief/material-icon-theme/5.32.0/file/PKief.material-icon-theme-5.32.0.vsix"
  },
  "theiaPluginsExcludeIds": [
    "vscode.github",
    "vscode.github-authentication",
    "vscode.microsoft-authentication",
    "ms-vscode.js-debug-companion",
    "vscode.extension-editing",
    "VisualStudioExptTeam.vscodeintellicode",
    "vscode.theme-abyss",
    "vscode.theme-defaults",
    "vscode.theme-kimbie-dark",
    "vscode.theme-monokai-dimmed",
    "vscode.theme-monokai",
    "vscode.theme-quietlight",
    "vscode.theme-red",
    "vscode.theme-solarized-dark",
    "vscode.theme-solarized-light",
    "vscode.theme-tomorrow-night-blue",
    "vscode.vscode-theme-seti"
  ],
  "workspaces": [
    "extensions/*",
    "applications/*"
  ],
  "dependencies": {
    "xml2js": "^0.6.2"
  }
}
