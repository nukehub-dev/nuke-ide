{
  "private": true,
  "name": "nuke-essentials",
  "version": "0.1.2",
  "description": "NukeIDE essential extensions",
  "license": "BSD-2-Clause",
  "keywords": [
    "theia-extension",
    "nuclear",
    "nukelab",
    "nukeide",
    "simulation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nukehub-dev/nuke-ide.git"
  },
  "bugs": {
    "url": "https://github.com/nukehub-dev/nuke-ide/issues"
  },
  "files": [
    "lib",
    "src"
  ],
  "dependencies": {
    "@theia/core": "1.69.0",
    "@theia/editor": "1.69.0",
    "@theia/filesystem": "1.69.0",
    "@theia/keymaps": "1.69.0",
    "@theia/monaco": "1.69.0",
    "@theia/preview": "1.69.0",
    "@theia/workspace": "1.69.0",
    "@theia/plugin-ext-vscode": "1.69.0",
    "@theia/ai-chat": "1.69.0",
    "@theia/ai-chat-ui": "1.69.0",
    "@theia/ai-core": "1.69.0",
    "@theia/ai-ide": "1.69.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "~5.4.5"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "scripts": {
    "prepare": "yarn run clean && yarn run build",
    "clean": "rimraf lib *.tsbuildinfo",
    "build": "tsc && yarn run copy-css",
    "copy-css": "cd src && find . -name '*.css' -exec cp --parents {} ../lib \\;",
    "watch": "tsc -w"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/about/browser/about-frontend-module"
    },
    {
      "frontend": "lib/getting-started/browser/getting-started-frontend-module",
      "backend": "lib/node/quote-backend-module"
    },
    {
      "frontend": "lib/ai-chat/browser/nuke-ai-chat-frontend-module"
    },
    {
      "frontend": "lib/theme/browser/theme-frontend-module"
    }
  ]
}
