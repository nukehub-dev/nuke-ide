{
  "private": true,
  "name": "nuke-visualizer",
  "version": "0.1.2",
  "description": "Advanced 3D visualization for nuclear computational data in NukeIDE",
  "license": "BSD-2-Clause",
  "keywords": [
    "theia-extension",
    "nuclear",
    "visualization",
    "trame",
    "paraview",
    "dagmc",
    "h5m",
    "vtk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nukehub-dev/nuke-ide.git"
  },
  "bugs": {
    "url": "https://github.com/nukehub-dev/nuke-ide/issues"
  },
  "files": [
    "lib",
    "src",
    "python",
    "resources"
  ],
  "dependencies": {
    "@theia/core": "1.69.0",
    "@theia/workspace": "1.69.0",
    "@theia/filesystem": "1.69.0",
    "@theia/process": "1.69.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "~5.4.5"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "scripts": {
    "prepare": "yarn run clean && yarn run build",
    "clean": "rimraf lib *.tsbuildinfo",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/visualizer-frontend-module",
      "backend": "lib/node/visualizer-backend-module"
    }
  ]
}
