{
  "private": true,
  "name": "nuke-core",
  "version": "0.1.2",
  "description": "Core infrastructure for NukeIDE - environment, configuration, and shared utilities",
  "license": "BSD-2-Clause",
  "keywords": [
    "theia-extension",
    "nuclear",
    "python",
    "conda"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nukehub-dev/nuke-ide.git"
  },
  "bugs": {
    "url": "https://github.com/nukehub-dev/nuke-ide/issues"
  },
  "homepage": "https://github.com/nukehub-dev/nuke-ide",
  "files": [
    "lib",
    "src"
  ],
  "dependencies": {
    "@theia/core": "1.72.3",
    "@theia/filesystem": "1.72.3",
    "@theia/preferences": "1.72.3",
    "@theia/terminal": "1.72.3",
    "@theia/workspace": "1.72.3"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "~7.0.2"
  },
  "scripts": {
    "prepare": "yarn clean && yarn build",
    "clean": "rimraf --glob lib *.tsbuildinfo",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/nuke-core-frontend-module",
      "backend": "lib/node/nuke-core-backend-module"
    }
  ]
}
