{
  "name": "nukelab-integration",
  "version": "0.1.2",
  "description": "Integrates NukeIDE with the NukeLab v2 gateway: account context, back navigation, logout, and app install.",
  "license": "BSD-2-Clause",
  "keywords": [
    "theia-extension",
    "nukelab",
    "nukeide",
    "gateway"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nukehub-dev/nuke-ide.git"
  },
  "bugs": {
    "url": "https://github.com/nukehub-dev/nuke-ide/issues"
  },
  "homepage": "https://github.com/nukehub-dev/nuke-ide",
  "files": [
    "lib",
    "src"
  ],
  "dependencies": {
    "@theia/core": "1.70.2"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "~5.4.5"
  },
  "scripts": {
    "prepare": "yarn clean && yarn build",
    "clean": "rimraf --glob lib *.tsbuildinfo",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/nukelab-integration-frontend-module",
      "backend": "lib/node/nukelab-integration-backend-module"
    }
  ]
}
