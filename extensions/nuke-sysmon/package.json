{
  "name": "nuke-sysmon",
  "version": "0.1.2",
  "description": "NukeIDE System Monitor - CPU, RAM, Disk, Network stats with graphs",
  "license": "BSD-2-Clause",
  "keywords": [
    "theia-extension",
    "system-monitor",
    "status-bar",
    "nukeide"
  ],
  "files": [
    "lib",
    "src"
  ],
  "dependencies": {
    "@theia/core": "1.72.3",
    "systeminformation": "^5.32.0"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "~7.0.2"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "scripts": {
    "prepare": "yarn run clean && yarn run build",
    "clean": "rimraf --glob lib *.tsbuildinfo",
    "build": "tsc && yarn run copy-css",
    "copy-css": "node ../../scripts/copy-css.js",
    "watch": "tsc -w"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/sysmon-frontend-module",
      "backend": "lib/node/sysmon-backend-module"
    }
  ]
}
